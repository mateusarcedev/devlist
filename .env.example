# =============================================================
# docker-compose production variables (injected via Infisical)
# Copy this file, fill in the values, and load with Infisical.
# =============================================================

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# API — Prisma connection strings
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/DB
DIRECT_URL=postgresql://USER:PASSWORD@postgres:5432/DB

# NextAuth (must be the same value in both api and web)
NEXTAUTH_SECRET=

# Web — public API URL (baked into the browser bundle at build time)
NEXT_PUBLIC_URL_API=https://api.yourdomain.com

# Web — internal API URL for server-side requests (uses Docker network)
URL_API=http://api:3001

# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=
GITHUB_TOKEN=

# Web
NEXTAUTH_URL=https://yourdomain.com
